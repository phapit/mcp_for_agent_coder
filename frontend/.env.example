# URL backend nhìn từ máy chạy Vite (dev server).
# Docker cấp host-port ngẫu nhiên: tìm bằng `docker port knowledge_service 8002`
# hoặc trỏ qua nginx-proxy (vd http://knowledge-api.mcp.local).
VITE_KNOWLEDGE_TARGET=http://localhost:8002
VITE_AGENT_TARGET=http://localhost:8003

# API key của backend (SERVICE_API_KEY ở .env gốc của repo).
# CHỈ dùng ở dev server (node), Vite inject vào header X-API-Key — KHÔNG lọt vào bundle browser.
SERVICE_API_KEY=

# Cổng dev server (mặc định 5173)
VITE_PORT=5173
