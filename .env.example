# ============================================================================
# Obsidian-Wiki — Mẫu cấu hình môi trường
# Copy thành .env rồi điền giá trị: cp .env.example .env
# Giá trị ghi sẵn là mặc định (docker-compose.yml / code); bỏ trống = bắt buộc điền.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Bảo mật & giới hạn request (bắt buộc cho cả 2 service)
# ----------------------------------------------------------------------------
# Khóa API chung giữa agent_service ↔ knowledge_service (header X-API-Key).
# BẮT BUỘC — service từ chối khởi động khi để trống.
SERVICE_API_KEY=

# Số request tối đa mỗi phút cho 1 IP (0 = tắt rate limit).
RATE_LIMIT_PER_MINUTE=120

# Kích thước tối đa (MB) của body upload (/ingest-excel/upload).
MAX_UPLOAD_SIZE_MB=20

# Danh sách origin trình duyệt được phép (CORS), phân tách bằng dấu phẩy.
# Để trống = không bật CORS middleware.
ALLOWED_ORIGINS=

# Timeout (giây) khi health-check gọi các dependency (Qdrant, Mongo, Ollama...).
DEPENDENCY_CHECK_TIMEOUT=5.0

# Mức log (DEBUG/INFO/WARNING/ERROR). Log xuất dạng JSON có correlation_id;
# gửi X-Request-ID trong request để trace xuyên suốt agent_service → knowledge_service.
LOG_LEVEL=INFO

# Nhãn môi trường gắn vào metadata mỗi chunk trong Qdrant (dùng để filter search).
ENVIRONMENT=local

# ----------------------------------------------------------------------------
# 2. Model AI — sinh câu trả lời (/answer) & vision (caption ảnh Excel)
# ----------------------------------------------------------------------------
# OpenAI: dùng khi use_online_model=1. Để trống nếu chỉ dùng Ollama local.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local (use_online_model=0, mặc định).
# LƯU Ý: phải trỏ alias "wiki-ollama" — tên "ollama" bị trùng với container
# backend-ollama-1 trên mạng docker_global_bridge, DNS sẽ trỏ nhầm (postmortem 2026-07-16).
OLLAMA_BASE_URL=http://wiki-ollama:11434/v1
OLLAMA_MODEL=llama3.2:3b

# Vision LLM để caption ảnh nhúng trong Excel: "openai" hoặc "anthropic".
VISION_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-5

# ----------------------------------------------------------------------------
# 3. Chất lượng tìm kiếm (kết quả kiểm thử 2026-07-16 — docs/Knowledge-Ingestion.md §7)
# ----------------------------------------------------------------------------
# Bật keyword search (BM25 + RRF) song song với vector search. 1=bật, 0=chỉ dense.
HYBRID_SEARCH_ENABLED=1

# Bật cross-encoder rerank. Kiểm thử: OFF = hit rate 50%, ON (mmarco) = 100%.
# Lần bật đầu tiên sẽ tải model (~500MB) khi có request search đầu tiên.
RERANK_ENABLED=1

# Model rerank. PHẢI là model đa ngôn ngữ vì câu hỏi tiếng Việt:
# bản EN-only (cross-encoder/ms-marco-MiniLM-L-6-v2) làm hit rate rơi về 0%.
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# Ngưỡng điểm tối thiểu để chunk được đưa vào context (chống trả lời từ nhiễu):
# - MIN_SCORE_THRESHOLD: cosine similarity, áp dụng khi KHÔNG rerank.
# - MIN_RERANK_SCORE: xác suất sigmoid 0-1, áp dụng khi rerank bật.
MIN_SCORE_THRESHOLD=0.35
MIN_RERANK_SCORE=0.3

# Mỗi nhánh retriever lấy limit × hệ số này ứng viên trước khi trộn RRF (tối thiểu 20).
CANDIDATE_POOL_MULTIPLIER=4

# Hằng số k trong công thức Reciprocal Rank Fusion 1/(k+rank).
RRF_K=60

# Model embedding cho vector search (đổi model phải re-ingest force toàn bộ).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Phiên bản prompt của /answer: v1 (cũ, EN) | v2 (tiếng Việt, chống injection, citation).
PROMPT_VERSION=v2

# Số lượt hội thoại trước đó được chèn vào prompt khi client gửi session_id.
SESSION_CONTEXT_TURNS=5
# Số lượt tối đa lưu trong MongoDB cho mỗi session.
SESSION_MAX_TURNS=20

# ----------------------------------------------------------------------------
# 4. Ingestion — Markdown / Excel / NotebookLM
# ----------------------------------------------------------------------------
# Tự động chạy ingest nền sau khi export Excel/NotebookLM thành công. 1=bật.
AUTO_INGEST_AFTER_EXPORT=1

# Glob quét file Markdown để ingest vào Qdrant.
DOCS_GLOB=/app/project_data/docs/imported/**/*.md

# Kích thước chunk (ký tự) và độ chồng lấp giữa 2 chunk liên tiếp.
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Tên collection trong Qdrant.
COLLECTION_NAME=project_docs

# Số lần ingest lỗi tối đa trước khi document bị chuyển vào dead-letter.
MAX_INGEST_ATTEMPTS=3

# Thư mục Excel nguồn và thư mục Markdown đầu ra (đường dẫn trong container).
EXCEL_SOURCE_DIR=/app/project_data/excel_sources
EXCEL_OUTPUT_DIR=/app/project_data/docs/imported

# NotebookLM: thư mục xuất Markdown (mặc định = EXCEL_OUTPUT_DIR) và thư mục
# chứa file auth JSON (xem docs/huong-dan-tao-profile-cho-notebooklm.md).
NOTEBOOKLM_OUTPUT_DIR=/app/project_data/docs/imported
NOTEBOOKLM_AUTH_DIR=/app/project_data/notebooklm_auth

# ----------------------------------------------------------------------------
# 5. Kho dữ liệu — Qdrant & MongoDB
# ----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Chuỗi kết nối MongoDB đầy đủ (ưu tiên dùng biến này).
# Nếu có username/password chứa ký tự đặc biệt phải escape theo RFC 3986.
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=knowledge_service

# (Tùy chọn) thành phần rời để tự ghép MONGODB_URI ở hạ tầng ngoài repo.
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_PORT=27017

# Tên các collection MongoDB (hiếm khi cần đổi).
MONGODB_COLLECTION_NAME=project_notebook_configs
MONGODB_REGISTRY_COLLECTION=document_registry
MONGODB_SESSIONS_COLLECTION=chat_sessions
MONGODB_INGEST_HISTORY_COLLECTION=ingest_runs

# ----------------------------------------------------------------------------
# 6. agent_service
# ----------------------------------------------------------------------------
# Đường dẫn repo Git được mount trong container agent_service.
PROJECT_PATH=/app/project_data
# URL nội bộ tới knowledge_service (đã set sẵn trong docker-compose).
KNOWLEDGE_SERVICE_URL=http://knowledge_service:8002

# ----------------------------------------------------------------------------
# 7. Đánh giá RAG (scripts/rag_eval.py — chạy từ host)
# ----------------------------------------------------------------------------
# URL knowledge_service nhìn từ host. Port do Docker cấp ngẫu nhiên,
# xem bằng: docker port knowledge_service 8002
KNOWLEDGE_URL=http://localhost:8002

# ----------------------------------------------------------------------------
# 8. Kafka — pipeline ingest event-driven (bật bằng KAFKA_ENABLED=1)
# Topic khởi tạo bằng scripts/initial_kafka_topic.sh; contract xem job_contracts.py
# Khi bật: POST /ingest trả 202 + job_id (poll /ingest/jobs/{id}); worker trong
# knowledge_service consume tuần tự, retry qua topic retry, quá hạn vào DLQ.
KAFKA_ENABLED=0
# ----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=knowledge_service
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
# CA cert của broker (tự ký): lấy bằng `docker exec kafka cat /etc/kafka/secrets/ca-cert > secrets/kafka-ca-cert.pem`
KAFKA_SSL_CA_LOCATION=/app/project_data/secrets/kafka-ca-cert.pem
# Cert advertise theo IP nên tắt hostname verification (giống client.properties phía broker).
KAFKA_SSL_ENDPOINT_IDENTIFICATION=none
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Tên topic theo vòng đời job ingest.
KAFKA_TOPIC_DOCUMENT_INGEST_REQUESTED=document.ingest.requested
KAFKA_TOPIC_DOCUMENT_INGEST_COMPLETED=document.ingest.completed
KAFKA_TOPIC_DOCUMENT_INGEST_FAILED=document.ingest.failed
KAFKA_TOPIC_DOCUMENT_INGEST_RETRY=document.ingest.retry
KAFKA_TOPIC_DOCUMENT_INGEST_DLQ=document.ingest.dlq

# Consumer group & tham số poll/retry.
KAFKA_CONSUMER_GROUP_DOCUMENT_INGEST=knowledge-ingest
KAFKA_CONSUMER_GROUP_RESULT=knowledge-ingest-result
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_MAX_POLL_RECORDS=10
KAFKA_MAX_POLL_INTERVAL_MS=300000
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RETRY_BACKOFF_MS=1000
KAFKA_RETRY_MAX_ATTEMPTS=3
QDRANT_API_KEY=changeme-generate-with-openssl-rand-hex-32
