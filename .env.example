OPENAI_API_KEY=
VISION_PROVIDER=openai
ANTHROPIC_API_KEY=
# Required: services refuse to start when empty.
SERVICE_API_KEY=
# Optional hardening knobs (defaults shown).
RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_SIZE_MB=20
# Comma-separated list of allowed browser origins; empty = CORS disabled.
ALLOWED_ORIGINS=
# Ingestion metadata + dead-letter tuning.
ENVIRONMENT=local
MAX_INGEST_ATTEMPTS=3
